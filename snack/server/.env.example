# Server Port
PORT=5000

# MongoDB Atlas
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/snackpoint?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Environment
NODE_ENV=production

# CORS & Client URL
CLIENT_URL=https://your-vercel-domain.vercel.app

# File Upload (for production)
SERVER_URL=https://your-render-backend.onrender.com
